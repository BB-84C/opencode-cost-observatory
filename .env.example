HOST=127.0.0.1
PORT=41777
OPENCODE_DB_PATH=<path-to-opencode-db>
ANALYTICS_DB_PATH=./.run/analytics.db
# Use an absolute path outside .run; .env values are not shell-expanded.
PRICING_DB_PATH=C:/Users/<your-user>/.local/share/opencode-cost-observatory/pricing.db
# Prefer a local auth file when available; keep DASHBOARD_TOKEN as a fallback.
DASHBOARD_TOKEN_FILE=./.run/dashboard.token
# DASHBOARD_TOKEN=replace-with-local-token

# --- VPS uploader (opencode --usage triggers this) ---
INGEST_URL=https://tokenobs.bb84.ai/api/ingest
INGEST_TOKEN=  # generate via `openssl rand -hex 32`, must match VPS side
UPLOAD_INTERVAL_MS=300000
UPLOAD_BATCH_SIZE=5000
UPLOAD_CATCHUP_MAX_RPS=5
